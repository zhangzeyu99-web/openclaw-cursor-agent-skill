{
  "plugins": {
    "allow": [
      "openclaw-cursor-agent"
    ],
    "load": {
      "paths": [
        "C:/Users/Administrator/.openclaw/workspace/plugins/openclaw-cursor-agent"
      ]
    },
    "entries": {
      "openclaw-cursor-agent": {
        "enabled": true,
        "config": {
          "toolkitRoot": "C:/Users/Administrator/.openclaw/workspace/cursor-agent-system",
          "defaultProjectPath": "D:/project/openclaw",
          "executionMode": "direct",
          "timeoutMs": 120000,
          "shell": {
            "executable": "D:/Git/bin/bash.exe",
            "args": [],
            "workingDirectory": "",
            "wslDistro": ""
          }
        }
      }
    }
  }
}
